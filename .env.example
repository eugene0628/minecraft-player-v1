# ─────────────────────────────────────────────
#  Minecraft Server Connection
# ─────────────────────────────────────────────
MC_HOST=localhost
MC_PORT=25565
# Your bot's in-game username (for offline servers)
MC_USERNAME=SneakyBot
# Minecraft version of the server (e.g. 1.20.1, 1.19.4)
MC_VERSION=1.20.1
# Auth mode: "offline" for cracked servers, "microsoft" for official
MC_AUTH=offline

# ─────────────────────────────────────────────
#  Ollama LLM Settings
# ─────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
# Model to use — mistral and llama3.1:8b both work well on a 2019 MacBook Pro
OLLAMA_MODEL=mistral
# Set to false to disable Ollama and use only rule-based behavior
OLLAMA_ENABLED=true

# ─────────────────────────────────────────────
#  Bot Behavior Tuning
# ─────────────────────────────────────────────
# Log level: debug | info | warn | error
LOG_LEVEL=info
# How many seconds to wait before reconnecting after a disconnect
RECONNECT_DELAY_SECONDS=10
# Maximum reconnect attempts before giving up (0 = unlimited)
MAX_RECONNECT_ATTEMPTS=20
# How often (ms) the autonomous goal loop re-evaluates priorities
GOAL_TICK_MS=2000
